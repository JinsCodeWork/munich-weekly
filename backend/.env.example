# 🔐 JWT Configuration
JWT_SECRET=your-jwt-secret              # Long random string, used to sign tokens
JWT_EXPIRATION_MS=604800000             # Token expiration time in milliseconds (e.g. 7 days)

# ☁️ Cloudflare R2 Object Storage
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=your-bucket-name
CLOUDFLARE_R2_PUBLIC_URL=https://your-custom-img-domain.com   # Used by Cloudflare Worker to proxy images

# 📂 Optional: Local upload fallback (used in dev mode only)
UPLOADS_DIR=/uploads

# 📮 Mailjet Email Service
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_API_SECRET=your-mailjet-secret
APP_FRONTEND_URL=https://your-frontend-domain.com             # Used in password reset email link

# ✅ Cloudflare Turnstile CAPTCHA for anonymous submissions
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
ANONYMOUS_UPLOAD_TOKEN_EXPIRATION_MS=900000

# 🛢️ PostgreSQL Database
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=your-db-name