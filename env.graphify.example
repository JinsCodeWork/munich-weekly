# Copy variables into `.env.local` (repo root, gitignored).
# graphify bundled backends only include claude + kimi; this project registers
# DeepSeek via scripts/graphify_semantic_deepseek.py

DEEPSEEK_API_KEY=your-key-here
GRAPHIFY_DEEPSEEK_BASE_URL=https://api.deepseek.com
GRAPHIFY_DEEPSEEK_MODEL=deepseek-v4-flash
